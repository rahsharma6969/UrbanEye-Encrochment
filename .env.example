# -------- Database --------
POSTGRES_USER=urbaneye
POSTGRES_PASSWORD=urbaneye_pass
POSTGRES_DB=urbaneye
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://urbaneye:urbaneye_pass@db:5432/urbaneye

# -------- Redis --------
REDIS_HOST=redis
REDIS_PORT=6379

# -------- API --------
ENV=local
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*

# -------- Planetary Computer --------
MPC_SAS_TOKEN=   # leave empty or put token if you have one

# -------- ML pipeline --------
ML_CONFIG=./configs/config.yaml
ML_ITEMS_OUT=./outputs/stac_items.json
ML_CHIPS_INDEX=./outputs/chips_index.parquet
ML_ONNX_OUT=./models/urbeye_change.onnx

